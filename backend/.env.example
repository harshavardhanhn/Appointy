# Backend environment variables example
# Copy to .env and fill values before running

# MongoDB connection URI (without database name)
MONGODB_URI=mongodb+srv://appointy_user:REPLACE_PASSWORD@cluster0.example.mongodb.net
# If your network blocks SRV (mongodb+srv) DNS lookups, provide a standard (non-SRV) connection string here and it will be used as a fallback
MONGODB_URI_NOSRV=mongodb://appointy_user:REPLACE_PASSWORD@cluster0-shard-00-00.example.mongodb.net:27017,cluster0-shard-00-01.example.mongodb.net:27017,cluster0-shard-00-02.example.mongodb.net:27017

# Optional: database name (defaults to 'appointy')
MONGODB_DB=appointy


# JWT secret
JWT_SECRET=replace_with_secure_random_string

# Admin credentials (used by admin panel)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=strong_admin_password

# Note: This project no longer uses Cloudinary or Razorpay. File uploads are stored locally in `backend/uploads` and payments are handled by a local stub for testing.

# Server port (optional)
PORT=4000
